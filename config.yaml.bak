# -----------------------------------------------------------
# DevClaw - Configuration
# Generated by setup wizard
# -----------------------------------------------------------

# -- Assistant ---------------------------------------------
name: "DevClaw"
trigger: "@devclaw"
model: "glm-5"
timezone: "America/Sao_Paulo"
language: "en"
instructions: |
  You are a helpful personal assistant.
  Be concise and practical in your responses.
  Respond in Portuguese when the user writes in Portuguese.

# -- API Provider ------------------------------------------
# API keys are stored in the encrypted vault (.devclaw.vault)
# and injected at runtime. Do NOT put keys here.
api:
  base_url: "https://api.z.ai/api/anthropic"
  provider: "anthropic"

# -- Agent -------------------------------------------------
agent:
  max_iterations: 20
  max_tool_calls: 50
  timeout: 120s
  stream_tokens: true

# -- Access Control ----------------------------------------
access:
  default_policy: allow
  owners: []
  admins: []
  allowed_users: []
  blocked_users: []
  pending_message: "Access not authorized. Contact an admin."

# -- Workspaces --------------------------------------------
workspaces:
  default_workspace: "default"
  workspaces:
    - id: "default"
      name: "Default"
      description: "Default workspace for all users"
      active: true

# -- Channels ----------------------------------------------
channels:

# -- Memory ------------------------------------------------
memory:
  type: "file"
  path: "./data/memory.db"
  max_messages: 100
  compression_strategy: "summarize"

# -- Security ----------------------------------------------
security:
  max_input_length: 4096
  rate_limit: 30
  enable_pii_detection: false
  enable_url_validation: true
  tool_guard:
    enabled: true
    allow_destructive: true
    allow_sudo: true
    allow_reboot: true
    block_sudo: false

# -- Token Budget ------------------------------------------
token_budget:
  total: 128000
  reserved: 4096
  system: 500
  skills: 2000
  memory: 1000
  history: 8000
  tools: 4000

# -- Plugins -----------------------------------------------
plugins:
  dir: "./plugins"

# -- Skills ------------------------------------------------
skills:
  builtin: [calculator, web-search]
  clawdhub_dirs: ["./skills"]

# -- Scheduler ---------------------------------------------
scheduler:
  enabled: true
  storage: "./data/scheduler.db"

# -- Web UI -----------------------------------------------
webui:
  enabled: true
  address: ":8090"
  auth_token: "${DEVCLAW_WEBUI_TOKEN}"

# -- Logging -----------------------------------------------
logging:
  level: "info"
  format: "json"

# -- Background Routines ------------------------------------
routines:
  metrics:
    enabled: false
    interval: 1m
  memory_indexer:
    enabled: true
    interval: 5m

# -- Native Media ------------------------------------------
native_media:
  enabled: true
  store:
    base_dir: "./data/media"
    temp_dir: "./data/media/temp"
    max_file_size: 52428800
  service:
    max_image_size: 20971520
    max_audio_size: 26214400
    max_doc_size: 52428800
    temp_ttl: "24h"
    cleanup_enabled: true
    cleanup_interval: "1h"
  enrichment:
    auto_enrich_images: true
    auto_enrich_audio: true
    auto_enrich_documents: true

# -- Database Hub -------------------------------------------
database:
  path: "./data/devclaw.db"
  hub:
    backend: "sqlite"
    sqlite:
      path: "./data/devclaw.db"
      journal_mode: "WAL"
      busy_timeout: 5000
      foreign_keys: true
    memory:
      backend: "sqlite"
      path: "./data/memory.db"
